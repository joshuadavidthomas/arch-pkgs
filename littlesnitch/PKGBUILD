install=littlesnitch.install
options=(!strip !debug)
source=("obdev-littlesnitch-${pkgver}-${_pkgrel_upstream}-x86_64.pkg.tar.zst::https://obdev.at/downloads/littlesnitch-linux/littlesnitch-${pkgver}-${_pkgrel_upstream}-x86_64.pkg.tar.zst")
sha256sums=('3104e73859c2e72b88206ebf2e7e239a157ed154eb12f3972fb570285d52aec9')

