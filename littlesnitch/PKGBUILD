pkgname=littlesnitch
pkgver=1.0.9_1
pkgrel=1
pkgdesc="Monitors and controls outgoing network connections using eBPF"
arch=(x86_64)
url="https://obdev.at/products/littlesnitch-linux/"
license=('GPL-2.0-only' 'LicenseRef-proprietary')
depends=(systemd)
conflicts=(littlesnitch-bin)
install=littlesnitch.install
options=(!strip !debug)
_upstream_pkgver=${pkgver/_/-}
source=("obdev-littlesnitch-${_upstream_pkgver}-x86_64.pkg.tar.zst::https://obdev.at/downloads/littlesnitch-linux/littlesnitch-${_upstream_pkgver}-x86_64.pkg.tar.zst")
sha256sums=('e32defb37efa740cdaf57e05304aa4c420b9b0f0b6453098f1794639f8ed074f')

package() {
  cp -a "$srcdir/usr" "$pkgdir/usr"
}
