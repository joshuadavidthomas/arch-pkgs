post_install() {
  cat <<'EOF'
Little Snitch has been installed.

Enable and start the daemon with:
  systemctl enable --now littlesnitch.service

Then open the UI at:
  http://localhost:3031/
EOF
}

post_upgrade() {
  cat <<'EOF'
Little Snitch has been upgraded.

Restart the daemon to run the new version:
  systemctl try-restart littlesnitch.service
EOF
}
