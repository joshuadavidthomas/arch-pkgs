# Maintainer: Josh Thomas <josh@joshthomas.dev>

pkgname=paper-design
pkgver=0.1.13
pkgrel=1
pkgdesc="A collaborative design tool built on web standards with agent integration"
arch=(x86_64)
url="https://paper.design"
license=(custom:Proprietary)
depends=(
  gtk3
  libnotify
  nss
  libxss
  libxtst
  xdg-utils
  at-spi2-core
  util-linux-libs
  libsecret
)
optdepends=(
  'libappindicator-gtk3: system tray support'
)
provides=(paper-desktop)
options=(!strip !debug)
source=("paper-design-${pkgver}.deb::https://download.paper.design/linux/deb")
sha256sums=('aed6fec65778c7d4e6be5df966d2276969ac2573ae88ba40d5969428bc731660')

package() {
  cd "$srcdir"

  bsdtar -xf data.tar.* -C "$pkgdir/"

  # fix permissions on chrome-sandbox
  chmod 4755 "$pkgdir/opt/Paper/chrome-sandbox"

  # symlink binary to /usr/bin
  install -d "$pkgdir/usr/bin"
  ln -s /opt/Paper/paper-desktop "$pkgdir/usr/bin/paper-desktop"
}
