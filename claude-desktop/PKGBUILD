# Maintainer: Josh Thomas <josh@joshthomas.dev>

pkgname=claude-desktop
pkgver=1.17377.0
pkgrel=3
pkgdesc="Desktop application for Claude.ai"
arch=(x86_64)
url="https://claude.ai/download"
license=(custom:Proprietary)
depends=(
  gtk3
  libnotify
  nss
  xdg-utils
  at-spi2-core
  libdrm
  mesa
  libxcb
  libsecret
  glibc
  libxtst
  util-linux-libs
  xdg-desktop-portal
  xdg-desktop-portal-impl
  alsa-lib
  glib2
  ca-certificates
)
optdepends=(
  'libayatana-appindicator: system tray support'
  'gnome-keyring: GNOME secret storage'
  'kwallet: KDE secret storage'
  'qemu-system-x86: Claude Code VM support'
  'edk2-ovmf: UEFI firmware for Claude Code VM support'
  'virtiofsd: shared filesystem support for Claude Code VM support'
)
provides=(claude-desktop-bin)
conflicts=(claude-desktop-bin)
options=(!strip !debug)
install=claude-desktop.install
_deb_arch=amd64
source=("${pkgname}-${pkgver}-${_deb_arch}.deb::https://downloads.claude.ai/claude-desktop/apt/stable/pool/main/c/claude-desktop/claude-desktop_${pkgver}_${_deb_arch}.deb")
sha256sums=('563c8df8ee3b957ca234115980386e960007ed8cfc8cc04c77d58a8d43f6c018')

package() {
  cd "$srcdir"

  bsdtar -xf data.tar.* -C "$pkgdir/"

  # fix permissions on chrome-sandbox
  chmod 4755 "$pkgdir/usr/lib/claude-desktop/chrome-sandbox"

  # keep the upstream copyright with Arch license files
  install -Dm644 "$pkgdir/usr/share/doc/claude-desktop/copyright" "$pkgdir/usr/share/licenses/$pkgname/copyright"

  # remove Debian-only packaging metadata
  rm -rf "$pkgdir/usr/share/lintian"

  # Electron's safeStorage only tries the OS keyring (gnome-libsecret/kwallet)
  # when it recognizes XDG_CURRENT_DESKTOP as GNOME/KDE/Unity; on other
  # compositors (niri, Hyprland, Sway, ...) it silently falls back to no
  # keyring. Replace the plain symlink with a wrapper that forces the
  # gnome-libsecret backend via Chromium's --password-store switch, so it
  # still uses the real session's gnome-keyring without touching desktop
  # detection used elsewhere (theming, portals, etc).
  rm -f "$pkgdir/usr/bin/claude-desktop"
  cat > "$pkgdir/usr/bin/claude-desktop" <<'EOF'
#!/bin/sh
exec /usr/lib/claude-desktop/claude-desktop --password-store=gnome "$@"
EOF
  chmod 755 "$pkgdir/usr/bin/claude-desktop"

  # Cowork's bundled VM helper hardcodes Debian filesystem paths for its
  # QEMU dependencies (/usr/libexec/virtiofsd, /usr/share/OVMF/*) that don't
  # exist on Arch even with the equivalent packages installed (virtiofsd
  # lives at /usr/lib/virtiofsd; OVMF firmware lives under /usr/share/edk2).
  # Ship a tmpfiles.d snippet symlinking the Arch locations into the paths
  # the app expects; claude-desktop.install applies it on (un)install.
  install -Dm644 /dev/stdin "$pkgdir/usr/lib/tmpfiles.d/claude-desktop.conf" <<'EOF'
L+ /usr/libexec/virtiofsd - - - - /usr/lib/virtiofsd
L+ /usr/share/OVMF/OVMF_CODE_4M.fd - - - - /usr/share/edk2/x64/OVMF_CODE.4m.fd
L+ /usr/share/OVMF/OVMF_VARS_4M.fd - - - - /usr/share/edk2/x64/OVMF_VARS.4m.fd
EOF
}
